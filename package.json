{
  "name": "meddevkit",
  "private": true,
  "description": "Open-source medical development toolkit for healthcare AI applications",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/meddevkit/meddevkit.git"
  },
  "license": "MIT",
  "keywords": [
    "medical",
    "healthcare",
    "rag",
    "chunker",
    "phi",
    "hipaa",
    "nlp",
    "clinical-notes",
    "ai"
  ]
}
