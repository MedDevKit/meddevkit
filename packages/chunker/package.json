{
  "name": "@meddevkit/chunker",
  "version": "0.1.2",
  "description": "PHI-aware medical text chunker for RAG applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "medical",
    "healthcare",
    "rag",
    "chunker",
    "phi",
    "hipaa",
    "nlp",
    "clinical-notes",
    "text-processing"
  ],
  "author": "Lyndon Hughey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meddevkit/meddevkit.git",
    "directory": "packages/chunker"
  },
  "homepage": "https://github.com/meddevkit/meddevkit#readme",
  "bugs": {
    "url": "https://github.com/meddevkit/meddevkit/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
